# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/schoolms?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=*

# ── OTP (Twilio SMS — optional, for production) ───────────────────────────────
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# ── OTP (Nodemailer Email — optional, for production) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Load Testing (dev only — remove in production) ───────────────────────────
LOAD_TEST_SECRET=your_load_test_bypass_key
